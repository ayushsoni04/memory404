    "primary": "#8B5CF6",
    "light": "#A78BFA",
    "dark": "#6D28D9"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.svg",
  "navbar": {
    "links": [
      {
        "label": "App",
        "href": "https://memory404.vercel.app"
      },
      {
        "label": "GitHub",
        "href": "https://github.com/ayushsoni/memory404"
      }
    ],
