NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_publishable_key

# API base URL — Render backend in production; leave empty for same-origin /api (local Next.js)
NEXT_PUBLIC_API_URL=

# Page screenshots: Microlink → thum.io → mShots (validated). Optional override:
# SCREENSHOT_URL_TEMPLATE=https://image.thum.io/get/width/1200/noanimate/{url}

# MongoDB Atlas — server-only. URL-encode special characters in the password.
MONGODB_URI="mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB="memory404"

# Optional legacy Supabase JWT:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_jwt
