{
  "name": "memory404",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "backend:dev": "npm run dev --prefix backend",
    "postinstall": "prisma generate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "tsx --test tests/**/*.test.ts",
    "test:metadata": "tsx scripts/test-metadata.ts",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:pull": "prisma db pull",
    "db:resolve-baseline": "prisma migrate resolve --applied 20260405120000_init",
    "db:mongo:dry-run": "node --env-file=.env --env-file=.env.local --import tsx scripts/migrate-postgres-to-mongodb.ts",
    "db:mongo:migrate": "node --env-file=.env --env-file=.env.local --import tsx scripts/migrate-postgres-to-mongodb.ts --execute",
    "db:mongo:verify": "node --env-file=.env --env-file=.env.local --import tsx scripts/migrate-postgres-to-mongodb.ts --verify-only"
  },
  "dependencies": {
