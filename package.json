    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cuelume": "^0.1.2",
    "framer-motion": "^12.42.2",
    "gsap": "^3.14.2",
    "lucide-react": "^1.24.0",
    "mongodb": "^7.5.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.13.0",
    "swr": "^2.4.2",
    "tailwind-merge": "^3.6.0",
    "thinking-orbs": "^0.1.1",
    "tw-animate-css": "^1.4.0"
