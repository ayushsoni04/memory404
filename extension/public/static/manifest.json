{
  "manifest_version": 3,
  "name": "Linksavekren Quick Save",
  "description": "Save current tab to Linksavekren groups.",
  "version": "0.1.0",
  "action": {
    "default_title": "Save Link",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "omnibox": {
    "keyword": "lk"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+L",
        "mac": "Option+Shift+L"
      },
      "description": "Open Linksavekren Quick Save popup"
    }
  },
  "permissions": ["tabs", "activeTab", "scripting", "storage", "omnibox"],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://localhost:3000/*",
    "https://*/*",
    "http://*/*"
  ]
}
